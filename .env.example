# Copy to .env for local dev (`netlify dev`), and set the same values in the
# Netlify UI under Site settings > Environment variables for production.
# Never commit the real .env file.

# --- Lead capture -----------------------------------------------------------
# Where leads go: "highlevel" | "sheet" | "both" (highlevel + sheet backup) | "crm"
LEAD_DESTINATION=highlevel

# HighLevel (GoHighLevel / LeadConnector). Used for "highlevel"/"both".
# Token = a Private Integration token (pit-...); Location ID = the sub-account id.
# The 8 custom fields already exist in the account; the adapter resolves their IDs by key.
HIGHLEVEL_TOKEN=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
HIGHLEVEL_LOCATION_ID=xxxxxxxxxxxxxxxxxxxx

# Google Apps Script web-app URL (the /exec endpoint). Used for "sheet"/"both".
SHEET_ENDPOINT=https://script.google.com/macros/s/XXXXXXXX/exec

# Generic CRM fallback. Used for "crm".
# CRM_ENDPOINT=https://api.your-crm.com/v1/contacts
# CRM_API_KEY=sk_live_xxx

# --- PDF footer -------------------------------------------------------------
# The URL printed in the footer of every playbook page.
SITE_URL=assessment.enabledbd.com

# --- Local PDF testing only -------------------------------------------------
# Point this at a local Chrome/Edge to test PDFs under `netlify dev` without the
# Lambda Chromium build. Leave unset in production.
# Windows example:
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
